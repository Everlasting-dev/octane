{
  "name": "octane-signal-matrix",
  "version": "1.0.0",
  "private": true,
  "description": "Octane — ECU telemetry log analyzer (Next.js + Electron).",
  "author": "AK Everlasting Dev",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "gen:icons": "node scripts/gen-icons.mjs",
    "desktop": "next build && electron .",
    "electron": "electron .",
    "pack:win": "next build && electron-builder --win dir",
    "dist:win": "next build && electron-builder --win nsis",
    "publish:win": "next build && electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "dev.everlasting.octane",
    "productName": "Octane",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png",
      "signtoolOptions": {
        "publisherName": "AK Everlasting Dev"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Octane"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Everlasting-dev",
        "repo": "octane",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/analytics": "1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "42.4.0",
    "electron-builder": "26.15.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "postcss": "^8.5",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "2.15.4",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  }
}
